{
  "projectType": "cli-tool",
  "projectName": "PM — Project Manager for Claude Code",
  "projectDescription": "A lightweight Claude Code plugin that tracks epics, maintains an explicit detour stack, and enforces a reconcile gate so nothing is lost across context compaction or mid-session pivots.",
  "theme": "luma",
  "primaryColor": "#dcdccc",
  "lightColor": "#ffffff",
