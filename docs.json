              "concepts/epics-and-lanes",
              "concepts/detour-stack",
              "concepts/reconcile-gate",
              "concepts/state-and-project"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/daily-workflow",
              "guides/handling-detours",
              "guides/multi-agent-hierarchy",
              "guides/external-trackers",
              "guides/companion-plugins"
            ]
          }
        ]
      },
      {
