{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "PM for Claude Code",
  "colors": {
    "primary": "#dcdccc",
    "light": "#ffffff"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "https://raw.githubusercontent.com/cfdude/pm/main/img/logo-nav.svg",
